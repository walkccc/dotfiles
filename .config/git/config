[init]
  defaultBranch = main
[user]
  name = walkccc
  email = walkccray@gmail.com
[core]
  excludesfile = /Users/Jay/.gitignore_global
  editor = nvim
[alias]
  br = branch
  co = checkout
  cm = commit -m
  d = diff
  dv = difftool -t vimdiff -y
  gl = config --global -l
  ll = log --oneline
  pf = push -f
  ra = rebase --abort
  rc = rebase --continue
  rr = rebase -i --root
  rv = remote -v
  su = stash -u
  sc = stash clear
  sp = stash pop
  st = status -sb
